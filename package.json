{
  "name": "colony-bee-sdk",
  "version": "0.1.0",
  "description": "Colony Bee SDK - Agent 接入 Colony 系统的 JavaScript SDK",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      },
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "colony",
    "bee",
    "sdk",
    "agent",
    "multi-agent",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.1",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
